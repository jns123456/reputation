# Copy values into Cursor → Cloud Agents → Environment (not committed secrets)

HEROKU_API_KEY=
HEROKU_APP=reputation-juan
SITE_BASE_URL=https://www.predictstamp.com

# Sentry US cloud (matches Heroku SENTRY_DSN ingest.us.sentry.io)
# Personal Token (User settings → Personal Tokens), NOT Organization Token (org:ci only).
# Scopes: org:read, project:read, project:write, event:read, event:write
SENTRY_AUTH_TOKEN=
SENTRY_ORG=fsc-ti
SENTRY_PROJECT=predictstamp
SENTRY_REGION_URL=https://us.sentry.io

# Cloudflare R2 — forum images (scripts/provision_r2_media.sh)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
