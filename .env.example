DEBUG=True
DEV_FAST_MODE=False
SECRET_KEY=change-me-in-production

# i18n — optional GeoLite2-Country.mmdb for IP → country (pip install geoip2).
# Without it, country comes from CDN headers (e.g. CF-IPCountry behind Cloudflare).
# GEOIP_COUNTRY_PATH=/path/to/GeoLite2-Country.mmdb
MARKET_FULL_SYNC_INTERVAL_HOURS=6
MARKET_STALE_SYNC_INTERVAL_MINUTES=10
ENABLE_EMBEDDED_MARKET_SYNC=False
NAV_BADGE_CACHE_SECONDS=60
LEADERBOARD_CACHE_SECONDS=120
WORLD_CUP_MATCHES_PER_PAGE=24
CATEGORY_BROWSE_PAGE_SIZE=24
MARKET_LIST_PAGE_SIZE=24
EAS_ATTESTER_ID=proofrep-platform-v1
EAS_OFFCHAIN_SIGNING_KEY=change-me-for-production-attestations
EAS_CHAIN_ID=0
EAS_VERIFYING_CONTRACT=
EAS_DAILY_BATCH_ENABLED=True
EAS_DAILY_BATCH_HOUR_UTC=0
EAS_ONCHAIN_ANCHOR_ENABLED=False
EAS_ANCHOR_WALLET_ADDRESS=0xc224f482Fc5A57D82B1Dfe7bCe22Fd9971811a96
# Never commit the private key. Set only in Heroku/local secrets:
# EAS_ANCHOR_PRIVATE_KEY=0x...
EAS_BASE_RPC_URL=https://mainnet.base.org
EAS_CHAIN_ID=8453
# Base developer portal — domain verification meta tag (name="base:app_id")
BASE_APP_ID=6a1dd72fd510a5a848efc650
DATABASE_URL=postgres://reputation:reputation@localhost:5432/reputation
REDIS_URL=redis://localhost:6379/0
# Django cache: defaults to in-memory when DEBUG=True; set True with Redis running locally.
USE_REDIS_CACHE=False
POLYMARKET_EMBED_HEIGHT=420
POLYMARKET_EMBED_CONTENT_WIDTH=1200
MARKET_SYNC_CACHE_SECONDS=300
MARKET_SYNC_STALE_MINUTES=10
MARKET_SYNC_CATEGORY_LIMIT=100
MARKET_LIST_SORTED_LIMIT=200
POLYMARKET_TOP_VOLUME_MIN_SHARE=0.5
POLYMARKET_TOP_VOLUME_MAX_MARKETS=500
POLYMARKET_TOP_VOLUME_MAX_EVENT_PAGES=15
POLYMARKET_TAG_SYNC_MAX_EVENT_PAGES=10

# Imported market copy (Polymarket titles & descriptions)
MARKET_TRANSLATION_ENABLED=True
# Optional DeepL key for higher-quality Spanish (falls back to MyMemory when empty)
DEEPL_AUTH_KEY=
DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# Polymarket embed widget (https://embed.polymarket.com/)
# Features: chart, volume, liveActivity, buyButtons, yAxis, gridRows
POLYMARKET_EMBED_FEATURES=chart,volume,liveActivity
POLYMARKET_EMBED_THEME=light

# Profile avatars — deterministic PNGs from DiceBear (no S3). Seed = user primary key.
# AVATAR_DICEBEAR_BASE_URL=https://api.dicebear.com/9.x
# AVATAR_DICEBEAR_STYLE=identicon

# Engagement emails (transactional alerts, daily digest, streak reminders)
# Master switch; per-user control still lives in NotificationPreference.
ENGAGEMENT_EMAILS_ENABLED=True
# Absolute base URL used to build links inside emails (no request in tasks).
SITE_BASE_URL=http://localhost:8000
# In DEBUG, emails print to the console by default; set SMTP or Resend for production.
# Resend (recommended on Heroku): https://resend.com/api-keys — no SMTP add-on needed.
# With onboarding@resend.dev you can ONLY send to your Resend login email until a domain is verified.
RESEND_API_KEY=
RESEND_FROM_EMAIL=PredictStamp <onboarding@resend.dev>
EMAIL_BACKEND=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=PredictStamp <no-reply@predictstamp.app>

# Email verification for new accounts and email changes
EMAIL_VERIFICATION_REQUIRED=True
# Production HTTPS origin for CSRF (required behind TLS proxy if not inferred from ALLOWED_HOSTS)
# CSRF_TRUSTED_ORIGINS=https://predictstamp.app,https://www.predictstamp.app
EMAIL_VERIFICATION_TOKEN_HOURS=48
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
# DEBUG only: show a clickable verify link on the pending page when Resend blocks the recipient.
EMAIL_VERIFICATION_DEV_SHOW_LINK=True
# Scheduled re-engagement emails — OFF by default to control mailbox volume.
# Set to True to re-enable each one (also unschedules its Celery Beat job when False).
DIGEST_EMAILS_ENABLED=False
STREAK_REMINDER_EMAILS_ENABLED=False
MARKET_RESOLVING_REMINDERS_ENABLED=False
# UTC hour for the daily digest and the "streak ends tonight" reminder (used only when enabled).
DIGEST_SEND_HOUR_UTC=13
STREAK_REMINDER_HOUR_UTC=22

# Web Push (PWA) — leave blank to disable push entirely.
# Generate a key pair with: .venv/bin/vapid --gen  (writes private/public keys)
# or: .venv/bin/python -c "from py_vapid import Vapid01 as V; v=V(); v.generate_keys(); import base64; \
#   print(base64.urlsafe_b64encode(v.public_key.public_bytes(__import__('cryptography').hazmat.primitives.serialization.Encoding.X962, __import__('cryptography').hazmat.primitives.serialization.PublicFormat.UncompressedPoint)).decode())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@predictstamp.app

# Auth0 (optional) — additive "Continue with Auth0" login next to local accounts.
# Leave blank to hide the button. Create a "Regular Web Application" in the Auth0
# dashboard, then copy Domain / Client ID / Client Secret here.
# Allowed Callback URL:   http://localhost:8000/accounts/auth0/callback/
# Allowed Logout URL:     http://localhost:8000/
#
# Universal Login logo (Auth0 Dashboard → Branding → Universal Login):
#   Logo URL: https://www.predictstamp.com/brand/auth0-logo.jpg
#   Widget → Logo height: set to 100 (max) so the mark is readable on mobile.
#   Re-save Logo URL after deploy if Auth0 still shows a cached tiny image.
#   Regenerate asset: python scripts/optimize_auth0_logo.py (crops excess whitespace).
#   Local dev: upload static/images/predictstamp-auth0-logo.jpg (Auth0 cannot fetch localhost).
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Optional: API audience if you need Auth0-issued access tokens later.
AUTH0_AUDIENCE=

# Anti-abuse / human verification (AGENTS.md §16) ----------------------------
# Provider for the registration anti-bot signal: "noop" (default) or "turnstile".
# Never the only defense — it's one input to the risk score.
HUMAN_VERIFICATION_PROVIDER=noop
HUMAN_VERIFICATION_REQUIRED=False
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# MCP server (AGENTS.md §17) -------------------------------------------------
# Read tools are always available to token holders. Writes stay OFF until trust
# and abuse controls are proven — enable the master switch AND the per-tool flag.
MCP_ENABLED=True
MCP_WRITES_ENABLED=False
MCP_SUBMIT_PREDICTION_ENABLED=False
MCP_SUBMIT_COMMENT_ENABLED=False
MCP_CIRCUIT_BREAKER_THRESHOLD=25
MCP_CIRCUIT_BREAKER_WINDOW_SECONDS=300

# Automatic agent trust promotion (AGENTS.md §15) ---------------------------
# Rule-based promotion runs on a Celery beat cadence when enabled.
AGENT_TRUST_AUTOPROMOTE_ENABLED=True
AGENT_TRUST_PROMOTE_INTERVAL_HOURS=6
AGENT_TRUST_LIMITED_AGE_DAYS=1
AGENT_TRUST_STANDARD_AGE_DAYS=7
AGENT_TRUST_STANDARD_CONTRIBUTIONS=5
AGENT_TRUST_TRUSTED_AGE_DAYS=30
AGENT_TRUST_TRUSTED_CONTRIBUTIONS=25
AGENT_TRUST_ABUSE_BLOCK=3
AGENT_TRUST_ABUSE_WINDOW_DAYS=7
